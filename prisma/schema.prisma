// ============================================
// Future Sight — Database Schema
// ============================================
// Run: npx prisma migrate dev --name init
// Run: npx prisma generate

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth (NextAuth.js) ─────────────────────

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  hashedPassword String?
  image          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Auth relations
  accounts Account[]
  sessions Session[]

  // App data relations
  transactions      Transaction[]
  categories        Category[]
  merchantRules     MerchantRule[]
  importHistory     ImportRecord[]
  savingsGoals      SavingsGoal[]
  debts             Debt[]
  assets            Asset[]
  netWorthSnapshots NetWorthSnapshot[]
  budgets           Budget[]
  calendarEvents    CalendarEvent[]
  subscriptions     Subscription[]
  achievements      Achievement[]
  settings          UserSettings?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Financial Data ─────────────────────────

model Transaction {
  id                  String   @id @default(cuid())
  userId              String
  date                DateTime @db.Date
  description         String
  originalDescription String?
  amount              Decimal  @db.Decimal(12, 2)
  category            String   @default("Uncategorized")
  account             String   @default("Default")
  autoMatched         Boolean  @default(false)
  flagged             Boolean  @default(false)
  transferPairId      String?
  returnPairId        String?
  importRecordId      String?
  note                String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  importRecord ImportRecord? @relation(fields: [importRecordId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([userId, category])
  @@index([userId, account])
  @@index([userId, description])
  @@index([transferPairId])
  @@index([returnPairId])
  @@map("transactions")
}

model Category {
  id        String  @id @default(cuid())
  userId    String
  name      String
  type      String  @default("expense") // "income", "expense", "system"
  color     String?
  sortOrder Int     @default(0)
  isDefault Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@map("categories")
}

model MerchantRule {
  id       String @id @default(cuid())
  userId   String
  merchant String
  category String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, merchant])
  @@map("merchant_rules")
}

model ImportRecord {
  id         String   @id @default(cuid())
  userId     String
  filename   String
  sourceType String   @default("csv") // "csv", "pdf", "json"
  count      Int      @default(0)
  dateRange  String?
  importedAt DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId, importedAt])
  @@map("import_records")
}

// ─── Savings Goals ──────────────────────────

model SavingsGoal {
  id            String   @id @default(cuid())
  userId        String
  name          String
  targetAmount  Decimal  @db.Decimal(12, 2)
  currentAmount Decimal  @default(0) @db.Decimal(12, 2)
  deadline      DateTime? @db.Date
  linkedAccount String?
  icon          String?
  color         String?
  priority      String   @default("medium") // "low", "medium", "high"
  status        String   @default("active") // "active", "completed", "paused"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  contributions GoalContribution[]

  @@index([userId])
  @@map("savings_goals")
}

model GoalContribution {
  id        String   @id @default(cuid())
  goalId    String
  amount    Decimal  @db.Decimal(12, 2)
  note      String?
  date      DateTime @db.Date @default(now())
  createdAt DateTime @default(now())

  goal SavingsGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@map("goal_contributions")
}

// ─── Debt Tracker ───────────────────────────

model Debt {
  id              String   @id @default(cuid())
  userId          String
  name            String
  balance         Decimal  @db.Decimal(12, 2)
  originalBalance Decimal  @db.Decimal(12, 2)
  interestRate    Decimal  @db.Decimal(5, 3)
  minimumPayment  Decimal  @db.Decimal(12, 2)
  extraPayment    Decimal  @default(0) @db.Decimal(12, 2)
  dueDay          Int      @default(1)
  type            String   @default("other") // "mortgage", "auto", "student", "credit_card", "personal", "other"
  linkedAccount   String?
  status          String   @default("active") // "active", "paid_off"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("debts")
}

// ─── Assets & Net Worth ─────────────────────

model Asset {
  id        String   @id @default(cuid())
  userId    String
  name      String
  value     Decimal  @db.Decimal(14, 2)
  type      String   @default("other") // "checking", "savings", "investment", "retirement", "property", "vehicle", "other"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("assets")
}

model NetWorthSnapshot {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime @db.Date
  assets      Decimal  @db.Decimal(14, 2)
  liabilities Decimal  @db.Decimal(14, 2)
  netWorth    Decimal  @db.Decimal(14, 2)
  breakdown   Json?    // Detailed asset/liability breakdown
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("net_worth_snapshots")
}

// ─── Budgets ────────────────────────────────

model Budget {
  id           String  @id @default(cuid())
  userId       String
  category     String
  monthlyLimit Decimal @db.Decimal(12, 2)
  rollover     Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@map("budgets")
}

// ─── Calendar ───────────────────────────────

model CalendarEvent {
  id          String   @id @default(cuid())
  userId      String
  title       String
  date        DateTime @db.Date
  amount      Decimal? @db.Decimal(12, 2)
  type        String   @default("bill") // "bill", "payday", "reminder", "custom"
  recurring   String?  // "monthly", "biweekly", "weekly", "yearly"
  category    String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("calendar_events")
}

// ─── Subscriptions ──────────────────────────

model Subscription {
  id            String   @id @default(cuid())
  userId        String
  name          String
  amount        Decimal  @db.Decimal(12, 2)
  frequency     String   @default("monthly") // "monthly", "yearly", "weekly"
  category      String   @default("Subscriptions")
  nextBillDate  DateTime? @db.Date
  isAutoDetected Boolean @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("subscriptions")
}

// ─── Achievements ───────────────────────────

model Achievement {
  id         String   @id @default(cuid())
  userId     String
  key        String
  unlockedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@map("achievements")
}

// ─── User Settings ──────────────────────────

model UserSettings {
  id            String  @id @default(cuid())
  userId        String  @unique
  darkMode      Boolean @default(false)
  currency      String  @default("USD")
  locale        String  @default("en-US")
  dashPeriod    String  @default("all")
  sidebarOpen   Boolean @default(true)
  budgetRollover Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}
