# ─── Database ────────────────────────────────
# PostgreSQL connection string
# For Supabase: use the "Connection string" from Project Settings > Database
# Use the pooler URL (port 6543) for DATABASE_URL
DATABASE_URL="postgresql://user:password@localhost:5432/futuresight?schema=public"

# For Supabase: use the direct connection (port 5432) for migrations
# Not needed for local Docker setup
DIRECT_URL="postgresql://user:password@localhost:5432/futuresight?schema=public"

# ─── NextAuth ────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-change-this"

# The URL where your app is hosted
NEXTAUTH_URL="http://localhost:3000"

# ─── OAuth Providers (optional) ─────────────
# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub: https://github.com/settings/applications/new
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ─── Security ───────────────────────────────
# Set to "production" in deployment
NODE_ENV="development"
